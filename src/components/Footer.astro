---
// src/components/Footer.astro
const links = [
  { href: "/", label: "Home" },
  { href: "#servicos", label: "Serviços" },
  { href: "#como-funciona", label: "Processo" },
  { href: "#faq", label: "FAQ" },
];

// Configuração do WhatsApp (Padronizado com o restante do site)
const whatsappNumber = "5583981436560"; 
const whatsappMessage = encodeURIComponent("Olá! Gostaria de falar com um especialista sobre registro de marca.");
const whatsappLink = `https://wa.me/${whatsappNumber}?text=${whatsappMessage}`;
---

<footer class="footer" style="background-color: #2D1B41; color: #FFFFFF; padding: 80px 0 30px 0; font-family: sans-serif;">
  <div style="max-width: 1100px; margin: 0 auto; padding: 0 20px;">
    
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 50px; margin-bottom: 50px;">
      
      <div class="footer-info">
        <h3 style="color: #FFFFFF; font-size: 24px; font-weight: 800; line-height: 1.2; margin-bottom: 20px; font-family: serif;">
          A3 PROPRIEDADE<br/>
          <span style="color: #8E2D45;">INTELECTUAL</span>
        </h3>
        <p style="color: #A39BB0; line-height: 1.6; font-size: 15px;">
          Protegendo marcas e patentes com excelência jurídica, ética e foco total no resultado estratégico para o seu negócio.
        </p>
      </div>
      
      <div class="footer-links">
        <h4 style="color: #FFFFFF; text-transform: uppercase; font-size: 14px; letter-spacing: 2px; margin-bottom: 25px;">Navegação</h4>
        <ul style="list-style: none; padding: 0; margin: 0;">
          {links.map(link => (
            <li style="margin-bottom: 12px;">
              <a href={link.href} style="color: #A39BB0; text-decoration: none; transition: 0.3s; font-size: 15px;">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-contact">
        <h4 style="color: #FFFFFF; text-transform: uppercase; font-size: 14px; letter-spacing: 2px; margin-bottom: 25px;">Contato</h4>
        <p style="color: #A39BB0; font-size: 15px; margin-bottom: 10px;">
          E-mail: <a href="mailto:contato@a3pi.com.br" style="color: #A39BB0; text-decoration: none;">contato@a3pi.com.br</a>
        </p>
        <p style="color: #A39BB0; font-size: 15px; font-weight: 600;">Atendimento Nacional</p>
        <div style="margin-top: 25px;">
           <a href={whatsappLink} target="_blank" style="background-color: #8E2D45; color: #FFFFFF; padding: 12px 20px; border-radius: 6px; text-decoration: none; font-weight: 700; font-size: 13px; text-transform: uppercase; display: inline-block; transition: 0.3s;">
             Falar com Especialista →
           </a>
        </div>
      </div>
    </div>

    <div style="border-top: 1px solid rgba(255,255,255,0.1); padding-top: 30px; text-align: center;">
      <p style="color: #635A70; font-size: 13px; margin: 0;">
        &copy; 2026 A3 Propriedade Intelectual. Todos os direitos reservados.