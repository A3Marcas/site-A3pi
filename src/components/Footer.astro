---
// src/components/Footer.astro
const links = [
  { href: "/", label: "Home" },
  { href: "#servicos", label: "Serviços" },
  { href: "#como-funciona", label: "Processo" },
  { href: "#faq", label: "FAQ" },
];
---

<footer class="footer">
  <div class="container">
    
    <div class="footer-grid">
      
      <div class="footer-info">
        <a href="/" class="logo-link" aria-label="Voltar ao início">
          <img src="/assets/LOGO04.png" alt="A3 Propriedade Intelectual" class="img-logo-footer" />
        </a>
        <p class="footer-desc">
          Protegendo marcas e patentes com excelência jurídica, ética e foco total no resultado estratégico para o seu negócio.
        </p>
      </div>
      
      <div class="footer-links-container">
        <h4 class="footer-title">Navegação</h4>
        <ul class="footer-links">
          {links.map(link => (
            <li>
              <a href={link.href} class="footer-link">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div class="footer-contact">
        <h4 class="footer-title">Contato</h4>
        <p class="contact-text">
          E-mail: <a href="mailto:contato@a3pi.com.br" class="footer-link">contato@a3pi.com.br</a>
        </p>
        <p class="contact-highlight">Atendimento Nacional</p>
        <div class="btn-wrapper">
           <button class="btn-menta-outline open-modal-btn">Falar com Especialista →</button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 A3 Propriedade Intelectual. Todos os direitos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #001e13; /* Verde Profundo */
    color: #FFFFFF;
    padding: 80px 0 30px 0;
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 50px;
    margin-bottom: 50px;
  }

  .footer-info {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .logo-link {
    display: inline-block;
    margin-bottom: 20px;
    transition: opacity 0.2s;
  }

  .logo-link:hover {
    opacity: 0.85;
  }

  .img-logo-footer {
    height: 46px; /* Um bom tamanho para a logo no rodapé */
    width: auto;
    object-fit: contain;
  }

  .footer-desc {
    color: rgba(255, 255, 255, 0.7); /* Branco com 70% de opacidade para leitura suave */
    line-height: 1.6;
    font-size: 0.95rem;
    margin: 0;
  }

  .footer-title {
    color: #FFFFFF;
    text-transform: uppercase;
    font-size: 0.9rem;
    letter-spacing: 2px;
    margin-bottom: 25px;
    font-family: 'Montserrat', sans-serif;
  }

  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 12px;
  }

  .footer-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.3s;
    font-size: 0.95rem;
  }

  .footer-link:hover {
    color: #A9D1C0; /* Efeito Menta no hover */
  }

  .contact-text {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.95rem;
    margin-bottom: 10px;
  }

  .contact-highlight {
    color: #A9D1C0; /* Menta para destacar o atendimento nacional */
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0;
  }

  .btn-wrapper {
    margin-top: 25px;
  }

  .btn-menta-outline {
    background-color: transparent;
    color: #A9D1C0;
    border: 2px solid #A9D1C0;
    padding: 12px 20px;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: 'Inter', sans-serif;
  }

  .btn-menta-outline:hover {
    background-color: #A9D1C0;
    color: #000908;
  }

  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 30px;
    text-align: center;
  }

  .footer-bottom p {
    color: rgba(255, 255, 255, 0.5); /* Texto dos direitos autorais bem discreto */
    font-size: 0.85rem;
    margin: 0;
  }
</style>