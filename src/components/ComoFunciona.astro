---
// src/components/ComoFunciona.astro
const passos = [
  {
    numero: '01',
    titulo: 'Análise de Viabilidade',
    descricao: 'Verificamos se já existem marcas iguais ou similares que possam impedir seu registro.'
  },
  {
    numero: '02',
    titulo: 'Protocolo no INPI',
    descricao: 'Elaboramos e enviamos toda a documentação jurídica necessária para o órgão federal.'
  },
  {
    numero: '03',
    titulo: 'Acompanhamento',
    descricao: 'Monitoramos o processo semanalmente para responder a oposições ou exigências do INPI.'
  },
  {
    numero: '04',
    titulo: 'Certificado de Registro',
    descricao: 'Após a concessão, você recebe o certificado válido por 10 anos em todo o Brasil.'
  }
];
---

<section id="como-funciona" style="padding: 80px 0; background-color: #FFFFFF; font-family: sans-serif;">
  <div style="max-width: 1200px; margin: 0 auto; padding: 0 20px;">
    
    <div style="text-align: center; margin-bottom: 50px;">
      <span style="color: #8E2D45; font-weight: 700; text-transform: uppercase; letter-spacing: 2px; font-size: 14px; display: block; margin-bottom: 10px;">
        Passo a Passo
      </span>
      <h2 style="color: #2D1B41; font-size: 42px; margin: 0; font-weight: 800;">
        O Caminho para sua Marca Registrada
      </h2>
    </div>

    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 25px;">
      {passos.map(p => (
        <div style="background: #FFFFFF; padding: 40px 25px; border-radius: 15px; border: 1px solid #E0E0E0; position: relative; overflow: hidden; min-height: 220px; box-shadow: 0 10px 30px rgba(0,0,0,0.05);">
          
          <div style="position: relative; z-index: 2;">
            <h3 style="color: #2D1B41; font-size: 22px; margin-bottom: 15px; font-weight: 700;">
              {p.titulo}
            </h3>
            <p style="color: #444444; font-size: 16px; line-height: 1.6; margin: 0;">
              {p.descricao}
            </p>
          </div>

          <span style="position: absolute; top: 10px; right: 15px; font-size: 70px; font-weight: 900; color: #F0F0F0; z-index: 1; line-height: 1;">
            {p.numero}
          </span>
          
        </div>
      ))}
    </div>
  </div>
</section>