---
// src/components/ComoFunciona.astro
const passos = [
  {
    numero: '01',
    titulo: 'Análise de Viabilidade',
    descricao: 'Verificamos se já existem marcas iguais ou similares que possam impedir seu registro.'
  },
  {
    numero: '02',
    titulo: 'Protocolo no INPI',
    descricao: 'Elaboramos e enviamos toda a documentação jurídica necessária para o órgão federal.'
  },
  {
    numero: '03',
    titulo: 'Acompanhamento',
    descricao: 'Monitoramos o processo semanalmente para responder a oposições ou exigências do INPI.'
  },
  {
    numero: '04',
    titulo: 'Certificado de Registro',
    descricao: 'Após a concessão, você recebe o certificado válido por 10 anos em todo o Brasil.'
  }
];
---

<section id="como-funciona" class="como-funciona">
  <div class="container">
    
    <div class="cabecalho text-center">
      <span class="tag-menta">Passo a Passo</span>
      <h2 class="titulo-secao">O Caminho para sua Marca Registrada</h2>
    </div>

    <div class="grid-passos">
      {passos.map(p => (
        <div class="passo-card-wrapper">
          <div class="passo-card">
            <div class="passo-conteudo">
              <h3 class="passo-titulo">{p.titulo}</h3>
              <p class="passo-desc">{p.descricao}</p>
            </div>
            <span class="passo-numero">{p.numero}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="cta-container">
      <button class="btn-menta-full open-modal-btn">Quero dar o primeiro passo</button>
    </div>

  </div>
</section>

<style>
  .como-funciona {
    padding: 100px 0;
    background-color: #FFFFFF; 
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .cabecalho {
    text-align: center;
    margin-bottom: 60px;
  }

  .tag-menta {
    color: #406962; 
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-size: 0.85rem;
    display: block;
    margin-bottom: 12px;
  }

  .titulo-secao {
    color: #000908; 
    font-size: clamp(2rem, 5vw, 2.8rem);
    margin: 0;
  }

  .grid-passos {
    display: grid;
    grid-template-columns: repeat(4, 1fr); 
    gap: 25px; /* Espaço de 25px entre os cards */
  }

  .passo-card-wrapper {
    position: relative;
  }

  /* Engenharia das Setas Conectoras Ampliadas */
  @media (min-width: 992px) {
    .passo-card-wrapper:not(:last-child)::after {
      content: '➔';
      position: absolute;
      right: -25px; /* Alinha exatamente no início do espaço do gap */
      top: 50%;
      transform: translateY(-50%);
      width: 25px; /* Ocupa a largura total do gap para centralizar perfeitamente */
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 2.2rem; /* Tamanho ampliado significativamente */
      color: #A9D1C0; 
      z-index: 5;
      opacity: 0.8;
      user-select: none;
    }
  }

  .passo-card {
    background: #F9F9F9; 
    padding: 40px 25px;
    border-radius: 12px;
    border: 1px solid #E2E8F0;
    position: relative;
    overflow: hidden;
    height: 100%;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .passo-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 30px rgba(3, 47, 46, 0.1); 
  }

  .passo-conteudo {
    position: relative;
    z-index: 2;
  }

  .passo-titulo {
    color: #001e13; 
    font-size: 1.4rem;
    margin-bottom: 15px;
  }

  .passo-desc {
    color: #406962; 
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
  }

  .passo-numero {
    position: absolute;
    top: 5px;
    right: 15px;
    font-size: 5rem;
    font-weight: 900;
    color: rgba(169, 209, 192, 0.25); 
    z-index: 1;
    line-height: 1;
    user-select: none;
  }

  .cta-container {
    text-align: center;
    margin-top: 50px;
  }

  /* Estilização ajustada para tag de botão */
  .btn-menta-full { 
    display: inline-block;
    background: #A9D1C0; 
    color: #000908; 
    border: none; 
    padding: 16px 36px;
    border-radius: 8px;
    font-weight: 700;
    font-size: 1.1rem;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 4px 15px rgba(169, 209, 192, 0.3);
  }
  
  .btn-menta-full:hover { 
    background: #032F2E; 
    color: #FFFFFF; 
    transform: translateY(-3px);
    box-shadow: 0 8px 25px rgba(3, 47, 46, 0.2);
  }

  @media (max-width: 991px) {
    .grid-passos {
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    }
  }
</style>