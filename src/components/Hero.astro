---
// Hero.astro - A3 Propriedade Intelectual
---

<section class="hero">
  <div class="container">
    <span class="tagline">Segurança Jurídica para seu Negócio</span>
    <h1 class="hero-title">Sua marca é seu patrimônio. <br/><span>Proteja-a agora.</span></h1>
    <p class="hero-description">Registramos sua marca no INPI com análise de viabilidade gratuita e acompanhamento total por especialistas.</p>
    
    <div class="cta-group">
      <button id="openModalBtn" class="btn-primary">
        Quero uma avaliação gratuita da minha marca
      </button>
      <a href="#servicos" class="btn-secondary">Nossos Serviços</a>
    </div>
  </div>

  <div id="leadModal" class="modal-overlay">
    <div class="modal-content">
      <button type="button" class="close-btn" id="closeModalBtn">&times;</button>
      
      <div class="modal-header">
        <h2>Avaliação de Viabilidade</h2>
        <p>Preencha os campos abaixo para que nossos especialistas realizem a busca oficial no INPI.</p>
      </div>
      
      <form id="viabilityForm">
        <div class="form-group">
          <label>Nome Completo</label>
          <input type="text" name="nome" placeholder="Seu nome" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>E-mail</label>
            <input type="email" name="email" placeholder="seu@email.com" required />
          </div>
          <div class="form-group">
            <label>WhatsApp</label>
            <input type="tel" name="whatsapp" placeholder="(00) 00000-0000" required />
          </div>
        </div>

        <div class="form-group">
          <label>Nome da Marca</label>
          <input type="text" name="marca" placeholder="Nome da marca a proteger" required />
        </div>

        <div class="form-row">
          <div class="form-group">
            <label>CNPJ</label>
            <input type="text" name="cnpj" placeholder="00.000.000/0000-00" />
          </div>
          <div class="form-group">
            <label>Ramo de Atuação</label>
            <input type="text" name="ramo" placeholder="Ex: Moda, Alimentação..." required />
          </div>
        </div>

        <button type="submit" class="btn-submit">Solicitar via WhatsApp</button>
      </form>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 120px 0;
    background-color: #2D1B41; 
    color: #FFFFFF !important; 
    text-align: center;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .container { max-width: 1000px; margin: 0 auto; padding: 0 20px; z-index: 2; }
  
  .tagline { 
    color: #A6445C !important; 
    font-weight: bold; 
    text-transform: uppercase; 
    letter-spacing: 2px; 
    display: block;
    margin-bottom: 15px;
  }

  .hero-title { 
    font-size: clamp(2.2rem, 5vw, 3.8rem); 
    margin: 20px 0; 
    font-family: serif; 
    color: #FFFFFF !important; 
    line-height: 1.2;
  }

  .hero-description { 
    font-size: 1.25rem; 
    margin-bottom: 45px; 
    color: #FFFFFF !important; 
    opacity: 0.9;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }

  .cta-group { display: flex; gap: 20px; justify-content: center; flex-wrap: wrap; }

  .btn-primary { 
    background-color: #8E2D45; 
    color: #FFFFFF !important; 
    padding: 20px 35px; 
    border-radius: 8px; 
    border: none; 
    font-weight: bold; 
    cursor: pointer;
    transition: 0.3s;
    font-size: 1.1rem;
  }
  .btn-primary:hover { background-color: #A6445C; transform: translateY(-3px); }

  .btn-secondary {
    border: 2px solid #FFFFFF;
    color: #FFFFFF !important;
    padding: 18px 35px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: bold;
    transition: 0.3s;
  }
  .btn-secondary:hover { background: rgba(255, 255, 255, 0.1); }

  /* MODAL ESTILOS */
  .modal-overlay {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(8px);
    z-index: 10000;
    justify-content: center;
    align-items: center;
  }

  .modal-content {
    background: #FFFFFF;
    color: #2D1B41;
    padding: 40px;
    border-radius: 16px;
    width: 95%;
    max-width: 580px;
    position: relative;
    box-shadow: 0 20px 50px rgba(0,0,0,0.3);
  }

  .close-btn {
    position: absolute;
    top: 15px;
    right: 20px;
    font-size: 32px;
    background: none;
    border: none;
    cursor: pointer;
    color: #2D1B41;
  }

  .modal-header h2 { color: #2D1B41; font-family: serif; font-size: 2rem; margin-bottom: 10px; }
  .modal-header p { color: #666; font-size: 1rem; margin-bottom: 30px; }

  .form-group { margin-bottom: 20px; text-align: left; flex: 1; }
  .form-group label { display: block; font-size: 0.85rem; font-weight: bold; color: #8E2D45; margin-bottom: 8px; }
  .form-row { display: flex; gap: 20px; }

  input {
    width: 100%;
    padding: 14px;
    border: 1px solid #ddd;
    border-radius: 8px;
    font-size: 1rem;
    box-sizing: border-box;
  }

  .btn-submit {
    width: 100%;
    background-color: #8E2D45;
    color: white;
    padding: 18px;
    border: none;
    border-radius: 8px;
    font-weight: bold;
    cursor: pointer;
    font-size: 1.1rem;
    transition: 0.3s;
  }
  .btn-submit:hover { background-color: #2D1B41; }

  @media (max-width: 768px) {
    .form-row { flex-direction: column; gap: 0; }
    .hero-title { font-size: 2.2rem; }
    .modal-content { padding: 30px 20px; }
  }
</style>

<script>
  const setupModal = () => {
    const modal = document.getElementById('leadModal');
    const openBtn = document.getElementById('openModalBtn');
    const closeBtn = document.getElementById('closeModalBtn');
    const form = document.getElementById('viabilityForm') as HTMLFormElement;

    if (!modal || !openBtn || !closeBtn) return;

    openBtn.onclick = () => {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
    };

    const close = () => {
      modal.style.display = 'none';
      document.body.style.overflow = 'auto';
    };

    closeBtn.onclick = close;
    window.onclick = (e) => { if (e.target === modal) close(); };

    if (form) {
      form.onsubmit = (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const texto = `*SOLICITAÇÃO DE AVALIAÇÃO GRATUITA*%0A%0A` +
                      `*Nome:* ${formData.get('nome')}%0A` +
                      `*WhatsApp:* ${formData.get('whatsapp')}%0A` +
                      `*Marca:* ${formData.get('marca')}%0A` +
                      `*CNPJ:* ${formData.get('cnpj')}%0A` +
                      `*Ramo:* ${formData.get('ramo')}`;
        
        window.open(`https://wa.me/5583981436560?text=${texto}`, '_blank');
        close();
        form.reset();
      };
    }
  };

  setupModal();
  document.addEventListener('astro:after-swap', setupModal);
</script>