---
// src/components/Servicos.astro

const servicos = [
  {
    titulo: 'Registro de Marca Nacional',
    descricao: 'Proteja sua marca no território brasileiro. Inclui busca prévia, classificação Nice, protocolo no INPI e acompanhamento até a concessão.',
    destaque: false,
    itens: [
      'Busca de anterioridade no INPI',
      'Definição da classe Nice',
      'Elaboração e protocolo do pedido',
      'Monitoramento do processo',
      'Resposta a exigências',
    ],
  },
  {
    titulo: 'Registro + Monitoramento Ativo',
    descricao: 'Tudo do plano essencial mais vigilância contínua de sua marca após o registro. Receba alertas de pedidos conflitantes e proteja seu ativo.',
    destaque: true,
    itens: [
      'Tudo do Registro Nacional',
      'Monitoramento pós-concessão',
      'Alertas de conflito por e-mail',
      'Relatório semestral de status',
      'Consultoria prioritária',
    ],
  },
  {
    titulo: 'Consulta de Viabilidade',
    descricao: 'Antes de investir no registro, verifique se sua marca tem chances reais de aprovação. Relatório técnico completo em até 48 horas.',
    destaque: false,
    itens: [
      'Busca na base do INPI',
      'Análise de colidência',
      'Relatório técnico escrito',
      'Recomendação de estratégia',
      'Sem compromisso de contratação',
    ],
  },
];
---

<section id="servicos" class="servicos-section">
  <div class="container">
    <div class="cabecalho text-center">
      <span class="tag-menta">Nossos serviços</span>
      <h2 class="titulo-servicos">Soluções em propriedade intelectual</h2>
      <div class="divisor-verde"></div>
      <p class="subtitulo-servicos">
        Honorários transparentes e sem taxas ocultas.
        As taxas oficiais do INPI são cobradas à parte e informadas antes do início.
      </p>
    </div>

    <div class="grid-3 servicos-grade">
      {servicos.map(s => (
        <div class={`card servico-card ${s.destaque ? 'servico-destaque' : ''}`}>
          {s.destaque && <div class="badge-menta">Mais contratado</div>}
          <h3>{s.titulo}</h3>
          <p class="servico-desc">{s.descricao}</p>
          
          <ul class="servico-itens">
            {s.itens.map(item => (
              <li>
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <path d="M3 8l3.5 3.5L13 4.5" stroke={s.destaque ? "#A9D1C0" : "#032F2E"}
                        stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
          <a href="#contato" class={`btn-acao ${s.destaque ? 'btn-menta-full' : 'btn-verde-outline'}`}>
            Solicitar orçamento
          </a>
        </div>
      ))}
    </div>

    <p class="aviso-inpi">
      * As taxas oficiais do INPI variam conforme o porte da empresa (MEI, ME, EPP, demais).
      Informaremos o valor exato antes do protocolo.
      <a href="https://www.gov.br/inpi/pt-br/servicos/marcas/tabela-de-retribuicoes" target="_blank" rel="noopener">
        Ver tabela oficial do INPI →
      </a>
    </p>
  </div>
</section>

<style>
.servicos-section { padding: 80px 0; background-color: #FFFFFF; }
.cabecalho { margin-bottom: 56px; text-align: center; }

.tag-menta {
    color: #406962;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 0.85rem;
}

.titulo-servicos { color: #000908; margin-top: 12px; font-size: 2.5rem; }

.divisor-verde { 
    width: 60px; 
    height: 3px; 
    background: #032F2E; 
    margin: 16px auto 0; 
}

.subtitulo-servicos {
    max-width: 520px; 
    margin: 20px auto 0; 
    color: #001e13; 
    font-size: 1.05rem;
}

.servicos-grade { display: grid; grid-template-columns: repeat(3, 1fr); gap: 30px; margin-top: 40px; align-items: stretch; position: relative; }

/* Estilos base dos Cards */
.servico-card {
  display: flex;
  flex-direction: column;
  padding: 40px 30px;
  background: #F9F9F9; 
  border: 1px solid #E2E8F0;
  border-radius: 12px;
  transition: transform 0.3s, box-shadow 0.3s;
}

.servico-card:hover { transform: translateY(-5px); box-shadow: 0 10px 30px rgba(3, 47, 46, 0.1); }

.servico-card h3 { color: #001e13; margin-bottom: 15px; font-size: 1.4rem;}

.servico-desc { 
    font-size: 0.95rem; 
    color: #406962 !important; 
    margin-bottom: 30px; 
    padding-bottom: 25px;
    border-bottom: 1px solid rgba(169, 209, 192, 0.3); 
    line-height: 1.5;
}

.servico-itens {
  list-style: none;
  padding: 0;
  margin-bottom: 30px;
  flex-grow: 1;
}

.servico-itens li {
  display: flex;
  align-items: flex-start;
  gap: 10px;
  font-size: 0.95rem;
  color: #001e13;
  margin-bottom: 12px;
}

/* ==========================================================================
   PLANO EM DESTAQUE (Modificadores para o Card do Meio)
   ========================================================================== */
.servico-destaque {
  background: #032F2E !important; 
  border: 2px solid #032F2E !important;
  transform: scale(1.03);
  box-shadow: 0 15px 40px rgba(3, 47, 46, 0.25);
}

/* Corrigindo o erro do título escuro - Forçando Branco Puro */
.servico-card.servico-destaque h3 { 
  color: #FFFFFF !important; 
}

.servico-destaque .servico-desc {
  color: #A9D1C0 !important; 
}

.servico-destaque .servico-itens li {
  color: #FFFFFF !important; 
}

/* Badge Superior */
.badge-menta {
  position: absolute;
  top: -15px;
  left: 50%;
  transform: translateX(-50%);
  background: #A9D1C0; 
  color: #000908; 
  font-size: 0.75rem;
  font-weight: 700;
  padding: 5px 20px;
  border-radius: 50px;
  text-transform: uppercase;
}

/* Botões Customizados */
.btn-acao {
    display: inline-flex;
    justify-content: center;
    padding: 14px 24px;
    border-radius: 6px;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
}

/* Botão do Card em Destaque */
.btn-menta-full { background: #A9D1C0; color: #000908; border: none; }
.btn-menta-full:hover { background: #FFFFFF; }

/* Botões dos Cards Básicos */
.btn-verde-outline { background: transparent; border: 2px solid #032F2E; color: #032F2E; }
.btn-verde-outline:hover { background: #032F2E; color: #FFFFFF; }

.aviso-inpi {
  margin-top: 40px;
  text-align: center;
  font-size: 0.85rem;
  color: #406962;
}

.aviso-inpi a { color: #032F2E; text-decoration: underline; font-weight: bold; }

@media (max-width: 992px) {
    .servicos-grade { grid-template-columns: 1fr; }
    .servico-destaque { transform: scale(1); }
}
</style>