---
// src/components/Header.astro
const nav = [
  // A barra (/) no início garante que a hiperligação volte sempre à página principal!
  { href: '/#como-funciona', label: 'Como funciona' },
  { href: '/#servicos',      label: 'Serviços'      },
  { href: '/#sobre',         label: 'Quem somos'    },
  { href: '/#faq',           label: 'FAQ'           },
  { href: '/blog',           label: 'Blog'          }, 
];
---

<header class="header" id="header">
  <div class="container header-inner">

    <a href="/" class="logo" aria-label="A3 Propriedade Intelectual — voltar ao início">
      <img src="/assets/LOGO04.png" alt="A3 Propriedade Intelectual" class="img-logo" />
    </a>

    <nav class="nav-desktop" aria-label="Navegação principal">
      {nav.map(item => (
        <a href={item.href} class="nav-link">{item.label}</a>
      ))}
    </nav>

    <div class="header-actions">
      <button class="btn btn-primario btn-header open-modal-btn">Falar com especialista</button>
      <button class="hamburger" id="hamburger" aria-label="Abrir menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <nav class="nav-mobile" id="nav-mobile" aria-label="Menu mobile">
    {nav.map(item => (
      <a href={item.href} class="nav-mobile-link">{item.label}</a>
    ))}
    <button class="btn btn-primario open-modal-btn" style="margin-top:8px;text-align:center; width: 100%;">
      Falar com especialista
    </button>
  </nav>
</header>

<style>
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  background: #001e13; /* Verde Profundo */
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(255,255,255,0.1);
  transition: all 0.3s ease;
}

.header-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 72px;
  gap: 24px;
}

/* Forçando cor branca nas hiperligações */
.header-inner a:not(.logo), .nav-mobile-link {
  color: #FFFFFF !important;
  text-decoration: none;
  font-weight: 500;
}

/* Estilização do Logótipo em Imagem */
.logo {
  display: flex;
  align-items: center;
}

.img-logo {
  height: 42px; /* Altura ideal para o cabeçalho de 72px */
  width: auto;  /* Mantém a proporção da imagem */
  object-fit: contain;
  transition: opacity 0.2s ease;
}

.logo:hover .img-logo {
  opacity: 0.85; /* Efeito de clique visual nítido */
}

/* Menu Desktop */
.nav-desktop { display: flex; align-items: center; gap: 4px; }
.nav-link {
  padding: 8px 14px;
  border-radius: 6px;
  font-size: 0.9rem;
  transition: all 0.2s;
}
.nav-link:hover { background: rgba(169, 209, 192, 0.1); color: #A9D1C0 !important; }

.header-actions { display: flex; align-items: center; gap: 12px; }

/* Botão em Menta Claro */
.btn-primario {
  background-color: #A9D1C0 !important; /* Cor de conversão */
  color: #000908 !important; /* Texto Quase Preto para contraste */
  border: none !important;
  padding: 10px 22px;
  border-radius: 6px;
  font-weight: 600;
  transition: all 0.3s ease;
  display: inline-block;
  cursor: pointer;
}

.btn-primario:hover { 
  background-color: #FFFFFF !important; 
  transform: translateY(-2px);
}

/* Mobile Menu Base */
.hamburger { display: none; flex-direction: column; justify-content: space-between; width: 24px; height: 18px; background: none; border: none; cursor: pointer; }
.hamburger span { display: block; width: 100%; height: 2px; background: #FFFFFF; border-radius: 2px; transition: 0.3s; }
.nav-mobile { display: none; flex-direction: column; gap: 10px; padding: 16px 24px 20px; border-top: 1px solid rgba(255,255,255,0.1); background: #001e13; }
.nav-mobile-link { padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }

/* Ativação do Menu Mobile */
.nav-mobile.active { display: flex; }
.hamburger.active span:nth-child(1) { transform: translateY(8px) rotate(45deg); }
.hamburger.active span:nth-child(2) { opacity: 0; }
.hamburger.active span:nth-child(3) { transform: translateY(-8px) rotate(-45deg); }

@media (max-width: 768px) {
  .nav-desktop, .btn-header { display: none; }
  .hamburger { display: flex; }
  .img-logo { height: 36px; } /* Logótipo ligeiramente menor em telemóveis */
}
</style>

<script>
  // Lógica para abrir e fechar o menu no telemóvel
  const setupMobileMenu = () => {
    const hamburger = document.getElementById('hamburger');
    const navMobile = document.getElementById('nav-mobile');
    const mobileLinks = document.querySelectorAll('.nav-mobile-link');
    const modalBtns = document.querySelectorAll('.nav-mobile .open-modal-btn'); 

    if (!hamburger || !navMobile) return;

    hamburger.addEventListener('click', () => {
      hamburger.classList.toggle('active');
      navMobile.classList.toggle('active');
    });

    const closeMenu = () => {
        hamburger.classList.remove('active');
        navMobile.classList.remove('active');
    };

    mobileLinks.forEach(link => {
      link.addEventListener('click', closeMenu);
    });

    modalBtns.forEach(btn => {
        btn.addEventListener('click', closeMenu);
    });
  };

  setupMobileMenu();
  document.addEventListener('astro:after-swap', setupMobileMenu);
</script>