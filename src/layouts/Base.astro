---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import ModalCaptura from '../components/ModalCaptura.astro';
const { titulo, descricao } = Astro.props;
---
<!doctype html>
<html lang="pt-br">
  <head>
    <BaseHead title={titulo} description={descricao} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Montserrat:wght@600;700;800&display=swap" rel="stylesheet">
  </head>
  <body>
    <slot />
    <Footer />
    <ModalCaptura />
  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    background-color: #F8F9FA; 
    
    /* Fonte Padrão (Leitura): Aplicada no site inteiro automaticamente */
    font-family: 'Inter', sans-serif;
    color: #000908;
    -webkit-font-smoothing: antialiased; /* Deixa a fonte mais nítida no Chrome/Safari */
  }

  /* Fonte de Títulos (Impacto): Aplicada automaticamente em todos os Cabeçalhos */
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Montserrat', sans-serif;
    font-weight: 700;
    margin-top: 0;
  }

  *, *::before, *::after {
    box-sizing: inherit;
  }

  /* NOVA REGRA: O alinhamento universal do site */
  .container {
    width: 100%;
    max-width: 1100px; /* Segura o site para não esticar demais em monitores ultrawide */
    margin: 0 auto;    /* Centraliza tudo na tela */
    padding: 0 24px;   /* O respiro mágico nas laterais! */
  }
</style>